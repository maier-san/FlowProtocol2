@page "{relativepath}"
@model FlowProtocol2.Pages.FlowPages.RunModel
@{
    ViewData["Title"] = @Model.ScriptName;
}
<nav class="breadcrumb-nav">
    @for (int i = 0; i < Model.Breadcrumbs.Count; i++)
    {
        var item = Model.Breadcrumbs[i];
        @if (!string.IsNullOrEmpty(item.Path))
        {
            @if (i == 0)
            {
                <a asp-page="/FlowPages/SelectMain">@item.Name</a>
            }
            else
            {
                <a asp-page="./Select" asp-route-relativepath="@item.Path">@item.Name</a>
            }
        }
        else
        {
            <a href="@Model.ScriptBaseURL">@item.Name</a>
        }
        @if (i < Model.Breadcrumbs.Count - 1)
        {
            <span class="breadcrumb-separator">·</span>
        }
    }
</nav>
@if (Model.Errors.Any())
{
    <h2>@Model.ScriptName</h2>
    <hr>
    <p><strong>Hinweis:</strong> Beim Ausführen des Skriptes sind Fehler aufgetreten.
        Bitte wenden Sie sich an den Autoren der Vorlage oder einen Administrator, um die Korrekturen zu veranlassen:
    </p>
    <ol>
        @foreach (var eitem in Model.Errors)
        {
            <li>
                <strong>Fehler "@eitem.ErrorCode": @eitem.ErrorText</strong><br />
                Zeile @eitem.ReadContext.LineNumber in <i>@eitem.ReadContext.ScriptFilePath</i><br />
                <span style="color: #ff0000;">@eitem.ReadContext.CodeLine</span>
            </li>
        }
    </ol>
    <hr>
}
@if (Model.InputForm.InputItems.Any())
{
    <form method="post">
        @if (!string.IsNullOrEmpty(Model.InputForm.Title))
        {
            <h2>@Model.InputForm.Title</h2>
        }
        else if (!Model.Errors.Any())
        {
            <h2>@Model.ScriptName</h2>
        }
        @if (!string.IsNullOrEmpty(Model.InputForm.Description))
        {
            <p>@Model.InputForm.Description</p>
        }    
        @foreach (var k in Model.RunContext.GivenKeys)
        {
            <input type="hidden" asp-for="BoundVars[k]" />
        }
        @foreach (var inidx in Model.InputForm.InputItems)
        {
            @if (!string.IsNullOrEmpty(inidx.Section))
            {
                <h4>@inidx.Section</h4>
            }
            var tinidx = inidx as Core.IMTextInputElement;
            @if (tinidx != null)
            {
                <div class="rendered-form">
                    <div class="formbuilder-text form-group">
                        <label for="@inidx.Key" class="formbuilder-text-label">@inidx.Prompt<br></label>
                        @if (tinidx.HelpInfoBlock.HelpInfoLines.Any())
                        {
                            @await Html.PartialAsync("_IMHelpInfoBlock", tinidx.HelpInfoBlock)
                        }
                        <input type="text" class="form-control" access="false" id="@inidx.Key" asp-for="BoundVars[inidx.Key]"
                            maxlength="1000">
                    </div>
                </div>
                <br>
            }
            var tarea = inidx as Core.IMTextAreaElement;
            @if (tarea != null)
            {
                <div class="rendered-form">
                    <div class="formbuilder-text form-group">
                        <label for="@inidx.Key" class="formbuilder-text-label">@inidx.Prompt<br></label>
                        @if (tarea.HelpInfoBlock.HelpInfoLines.Any())
                        {
                            @await Html.PartialAsync("_IMHelpInfoBlock", tarea.HelpInfoBlock)
                        }
                        <textarea class="form-control" id="@inidx.Key" asp-for="BoundVars[inidx.Key]" rows="@tarea.ShowLines"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(tarea.UploadFilter))
                    {
                        <div style="margin-bottom: 10px; margin-top: 5px;">
                            <button type="button" class="btn btn-secondary btn-sm" onclick="UploadFileFunction('@inidx.Key', '@tarea.UploadFilter')">Aus Datei einfügen</button>
                        </div>
                    }
                </div>
                <br>
            }
            var ogidx = inidx as Core.IMOptionGroupElement;
            @if (ogidx != null)
            {
                <div class="formbuilder-radio-group form-group">
                    <label class="formbuilder-radio-group-label">@ogidx.Prompt</label>
                    @if (ogidx.HelpInfoBlock.HelpInfoLines.Any())
                    {
                        @await Html.PartialAsync("_IMHelpInfoBlock", ogidx.HelpInfoBlock)
                    }
                    <div class="radio-group">
                        @foreach (var op in ogidx.Options)
                        {
                            <div class="formbuilder-radio">
                                <span>
                                    <input value="@op.Key" type="radio" asp-for="BoundVars[ogidx.Key]" id="@op.UniqueKey">
                                    <label for="@op.UniqueKey">@op.Prompt</label>
                                </span>
                            </div>
                        }
                    </div>
                </div>
                <br>
            }
        }
        <button type="submit" class="btn btn-primary">Weiter</button>
    </form>
    @if (Model.NeedsUploadFunction)
    {
        <script>
            async function UploadFileFunction(textareaID, filterString) {
            // Versuche File System Access API zu verwenden
            if (window.showOpenFilePicker) {
                try {
                    const fileHandle = await window.showOpenFilePicker({
                        types: [{
                            description: 'Dateien',
                            accept: GetAcceptTypes(filterString)
                        }],
                        multiple: false
                    });
                    
                    if (!fileHandle || fileHandle.length === 0) return;
                    
                    const file = await fileHandle[0].getFile();
                    await ProcessUploadedFile(file, textareaID);
                    return;
                } catch (err) {
                    if (err.name !== 'AbortError') {
                        console.error('Fehler beim File System Access:', err);
                    }
                }
            }
            
            // Fallback: Verwende verstecktes Input-Element
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = ConvertFilterToAccept(filterString);
            input.onchange = async () => {
                if (input.files && input.files.length > 0) {
                    const file = input.files[0];
                    await ProcessUploadedFile(file, textareaID);
                }
            };
            input.click();
        }
        
        async function ProcessUploadedFile(file, textareaID) {
            try {
                // Prüfe, ob es eine Textdatei ist
                const istext = await IsTextFile(file);
                if (!istext) {
                    alert('Fehler: Es können nur Textdateien eingefügt werden.');
                    return;
                }
                
                // Lese die Datei
                const text = await file.text();
                const maxLength = 30000;
                
                let contentToInsert = text;
                let wasTruncated = false;
                
                if (text.length > maxLength) {
                    contentToInsert = text.substring(0, maxLength);
                    wasTruncated = true;
                }
                
                // Setze den Text im Textarea
                const textarea = document.getElementById(textareaID);
                textarea.value = contentToInsert;
                
                if (wasTruncated) {
                    alert(`Hinweis: Der Inhalt der Datei ist zu lang und wurde bei ${maxLength} Zeichen abgeschnitten.`);
                }
            } catch (err) {
                console.error('Fehler beim Verarbeiten der Datei:', err);
                alert('Fehler beim Lesen der Datei.');
            }
        }
        
        function ConvertFilterToAccept(filterString) {
            if (!filterString || filterString === '*.*') {
                return '.txt,.log,.csv,.xml,.json,.md,.html,.css,.js,.php,.py,.java,.cs,.cpp,.c,.h,.sql,.sh,.bat,.cmd';
            }
            return filterString.split(',').map(f => f.trim()).join(',');
        }
        
        function GetAcceptTypes(filterString) {
            const acceptTypes = {};
            if (!filterString || filterString === '*.*') {
                acceptTypes['*/*'] = ['.txt', '.log', '.csv', '.xml', '.json'];
            } else {
                const filters = filterString.split(',').map(f => f.trim());
                for (const filter of filters) {
                    if (filter === '*.*') {
                        acceptTypes['*/*'] = [];
                    } else if (filter.startsWith('*.')) {
                        const ext = filter.substring(1);
                        if (!acceptTypes['text/plain']) {
                            acceptTypes['text/plain'] = [];
                        }
                        if (!acceptTypes['text/plain'].includes(ext)) {
                            acceptTypes['text/plain'].push(ext);
                        }
                    }
                }
            }
            return acceptTypes;
        }
        
        async function IsTextFile(file) {
            try {
                // Prüfe die ersten Bytes, um festzustellen, ob es eine Textdatei ist
                const buffer = await file.slice(0, 512).arrayBuffer();
                const view = new Uint8Array(buffer);
                
                // Prüfe auf UTF-8 BOM
                if (view.length >= 3 && view[0] === 0xEF && view[1] === 0xBB && view[2] === 0xBF) {
                    return true;
                }
                
                // Prüfe auf UTF-16 BOM
                if (view.length >= 2 && ((view[0] === 0xFF && view[1] === 0xFE) || (view[0] === 0xFE && view[1] === 0xFF))) {
                    return true;
                }
                
                // Prüfe ob Datei null bytes enthält (Indikator für Binärdatei)
                for (const byte of view) {
                    if (byte === 0) {
                        return false;
                    }
                }
                
                return true;
            } catch (err) {
                console.error('Fehler beim Überprüfen der Datei:', err);
                return false;
            }
        }
        </script>
    }
}
else
{
    @if (!string.IsNullOrEmpty(Model.Document.Title))
    {
        <h2>@Model.Document.Title</h2>
    }
    else
    {
        <h2>@Model.ScriptName</h2>
    }
    @foreach (var sec in Model.Document.Sections)
    {
        @if (!string.IsNullOrEmpty(sec.Headline))
        {
            <h4>@sec.Headline</h4>
        }
        @foreach (var bl in sec.Textblocks)
        {
            @await Html.PartialAsync("_OMTextBlock", bl)
        }
    }
    <p>
        <a href=@Model.ScriptBaseURL class="btn btn-primary">Neue Ausführung</a>
        <a asp-page="/FlowPages/SelectMain" class="btn btn-primary">Zurück zur Startseite</a>
    </p>
    @if (Model.NeedsCopyFunction)
    {
        <script>
            function CopyFunction(blockID) {
                const element = document.querySelector('#' + blockID);
                const storage = document.createElement('textarea');
                var cc = element.innerHTML;
                cc = cc.replaceAll('&lt;', String.fromCharCode(60));
                cc = cc.replaceAll('&gt;', String.fromCharCode(62));
                cc = cc.replaceAll('&quot;', String.fromCharCode(34));
                cc = cc.replaceAll('&amp;', String.fromCharCode(38));
                storage.value = cc;
                element.appendChild(storage);
                storage.select();
                storage.setSelectionRange(0, 99999);
                document.execCommand('copy');
                element.removeChild(storage);
            }
        </script>
    }
    @if (Model.NeedsSaveFunction)
    {
        <script>
            async function SaveFunction(blockID, suggestedFilename, suggestedEncoding) {
            const element = document.querySelector('#' + blockID);
            var cc = element.innerHTML;
            cc = cc.replaceAll('&lt;', String.fromCharCode(60));
            cc = cc.replaceAll('&gt;', String.fromCharCode(62));
            cc = cc.replaceAll('&quot;', String.fromCharCode(34));
            cc = cc.replaceAll('&amp;', String.fromCharCode(38));
            // Normalisiere Zeilenumbrüche zu CRLF
            cc = cc.replace(/\r?\n/g, '\r\n');
            // Erzeuge encoded data je nach gewünschter Codierung
            let dataToWrite;
            let blob;
            const enc = (suggestedEncoding || '').toLowerCase();
            if (enc && enc.indexOf('utf-16') === 0) {
                // UTF-16 LE mit BOM
                const buf = new Uint8Array(2 + cc.length * 2);
                buf[0] = 0xFF; buf[1] = 0xFE;
                for (let i = 0; i < cc.length; i++) {
                    const code = cc.charCodeAt(i);
                    buf[2 + i * 2] = code & 0xFF;
                    buf[2 + i * 2 + 1] = (code >> 8) & 0xFF;
                }
                dataToWrite = buf;
                blob = new Blob([dataToWrite], { type: 'text/plain' });
            } else if (enc && (enc === 'ascii' || enc === 'windows-1252' || enc === 'latin1' || enc === 'iso-8859-1')) {
                const arr = new Uint8Array(cc.length);
                for (let i = 0; i < cc.length; i++) arr[i] = cc.charCodeAt(i) & 0xFF;
                dataToWrite = arr;
                blob = new Blob([dataToWrite], { type: 'text/plain' });
            } else {
                // default UTF-8
                const te = new TextEncoder();
                dataToWrite = te.encode(cc);
                blob = new Blob([dataToWrite], { type: 'text/plain;charset=utf-8' });
            }

            // Prüfen, ob File System Access API unterstützt wird. Wenn ja, Dateiauswahldialog anzeigen
            if (window.showSaveFilePicker) {
                try {
                    const handle = await window.showSaveFilePicker({
                        suggestedName: suggestedFilename || 'Datei.txt'
                    });
                    const writable = await handle.createWritable();
                    await writable.write(dataToWrite);
                    await writable.close();                    
                    return;
                } catch (err) {
                    if (err.name === 'AbortError') return; // Benutzer hat abgebrochen
                    console.error('Fehler beim Speichern:', err);
                }
            }

            // Fallback für Firefox & Co.: Direktes herunterladen in den Download-Ordner
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = suggestedFilename || 'Datei.txt';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            }
        </script>
    }
}
